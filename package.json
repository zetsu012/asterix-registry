{
  "name": "dummy-vscode-extension",
  "displayName": "Dummy VSCode Extension",
  "description": "VSCode Extension with Vue Webview UI",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dummy-extension-container",
          "title": "Dummy Extension",
          "icon": "$(smiley)"
        }
      ]
    },
    "views": {
      "dummy-extension-container": [
        {
          "id": "dummy-extension-hello-world",
          "name": "Hello World",
          "type": "webview",
          "icon": "$(smiley)"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch",
    "package": "npm run build:webview && node esbuild.js --production",
    "clean": "rimraf out webview-ui/dist",
    "install:all": "npm install && cd webview-ui && npm install",
    "start:webview": "cd webview-ui && npm run dev",
    "build:webview": "cd webview-ui && npm run build",
    "build": "npm run clean && npm run compile && npm run build:webview"
  },
  "devDependencies": {
    "@types/node": "^18.x.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "@vscode/vsce": "^3.6.0",
    "esbuild": "^0.25.5",
    "eslint": "^8.49.0",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.0.1",
    "typescript": "^5.2.2"
  }
}
